# Configuração da API do Google Sheets
# Copie este arquivo para .env.local e substitua pelos seus valores reais

# Sua chave de API do Google Sheets
# Obtenha em: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_SHEETS_API_KEY=substitua_pela_sua_chave_de_api

# ID da sua planilha do Google Sheets
# Extraia da URL: https://docs.google.com/spreadsheets/d/[SEU_ID_AQUI]/edit
VITE_GOOGLE_SHEETS_ID=substitua_pelo_id_da_sua_planilha